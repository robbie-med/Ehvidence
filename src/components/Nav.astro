---
import SearchBox from '../islands/SearchBox.tsx';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const links = [
  { href: `${base}/`, label: 'Topics' },
  { href: `${base}/browse`, label: 'Browse' },
  { href: `${base}/compare`, label: 'Compare' },
  { href: `${base}/methodology`, label: 'Methodology' },
  { href: `${base}/glossary`, label: 'Glossary' },
  { href: `${base}/faq`, label: 'FAQ' },
  { href: `${base}/contribute`, label: 'Add data' },
];
---
<header class="site-header">
  <div class="wrap">
    <a class="brand" href={`${base}/`}>Eh<span>vidence</span></a>
    <SearchBox client:idle base={base} variant="nav" />
    <nav class="nav">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
  </div>
</header>
