---
import type { ComputedOutcome } from '../lib/derive';
import { fmtRR, fmtCI, fmtPct, fmtInt, fmtNN, dirWord, dirNoun, dispNnt } from '../lib/format';

interface Props {
  outcome: ComputedOutcome;
  status: string;
  showNnt?: boolean;
}
const { outcome, status, showNnt = true } = Astro.props;
const dir = outcome.outcome.direction;
const p = outcome.pooled;
const word = p ? dirWord(p.improvementPct, dir) : 'lower';
const noun = dirNoun(dir);
const mag = p ? Math.abs(p.improvementPct) : 0;
const nntVal = p ? dispNnt(p.nnt, p.nnh, dir) : null;
---
<div class={`summary-block ${status}`}>
  {p ? (
    <>
      <div class="headline">
        <span class="pct">{fmtPct(mag)}</span> {word} {noun} {outcome.outcome.label.toLowerCase()}
      </div>
      <div class="detail">
        Pooled RR {fmtRR(p.rr)} (95% CI {fmtCI(p.ciLow, p.ciHigh)}) across {p.k} studies{
          outcome.totalPatients > 0 ? `, ${fmtInt(outcome.totalPatients)} patients` : ''
        } (random-effects, I² {fmtPct(p.i2)}).
      </div>
      <div class="metrics">
        <div class="metric"><div class="v">{fmtRR(p.rr)}</div><div class="k">Pooled RR</div></div>
        <div class="metric"><div class="v">{fmtCI(p.ciLow, p.ciHigh)}</div><div class="k">95% CI</div></div>
        <div class="metric"><div class="v">{p.k}</div><div class="k">Studies</div></div>
        {outcome.totalPatients > 0 && (
          <div class="metric"><div class="v">{fmtInt(outcome.totalPatients)}</div><div class="k">Patients</div></div>
        )}
        {showNnt && (
          <div class="metric"><div class="v">{fmtNN(nntVal)}</div><div class="k">NNT</div></div>
        )}
      </div>
    </>
  ) : (
    <div class="detail">No poolable studies for this outcome yet.</div>
  )}
</div>
