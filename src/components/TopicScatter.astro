---
import type { ComputedTopic } from '../lib/derive';

interface Props {
  topics: ComputedTopic[];
}
const { topics } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Only plot topics with a pooled primary ratio effect and a patient count.
const raw = topics
  .map((t) => ({ t, p: t.primary.pooled }))
  .filter((d) => d.p && d.t.totalPatients > 0) as { t: ComputedTopic; p: NonNullable<ComputedTopic['primary']['pooled']> }[];

// Directional benefit on the primary outcome: positive always means "better",
// regardless of whether the outcome is lower- or higher-is-better. This is the
// same convention the topic pages use, so a favorable topic never plots as
// negative just because its outcome counts successes rather than events.
function benefitPct(rr: number, dir: string): number {
  return dir === 'higherIsBetter' ? (rr - 1) * 100 : (1 - rr) * 100;
}
const pts = raw.map((d) => ({
  t: d.t,
  x: Math.log10(Math.max(10, d.t.totalPatients)),
  yTrue: benefitPct(d.p.rr, d.t.primary.outcome.direction),
  rr: d.p.rr,
}));

// ---- geometry ----
const W = 760;
const H = 460;
const M = { top: 22, right: 20, bottom: 46, left: 58 };
const innerW = W - M.left - M.right;
const innerH = H - M.top - M.bottom;

// x = evidence volume (log10 patients)
const xs = pts.map((d) => d.x);
const xMin = Math.min(2, ...xs);
const xMax = Math.max(5, ...xs);

// y = directional benefit %, clamped to a fixed window so a single extreme
// topic can't compress everything else. Nearly all real interventions land in
// 0–90%, so the window is asymmetric (a shallow negative floor) to give that
// dense band room; anything below is drawn at the edge with a caret and its
// true value on the tooltip.
const yMin = -50;
const yMax = 100;

const xScale = (v: number) => M.left + ((v - xMin) / (xMax - xMin || 1)) * innerW;
const yScale = (v: number) => M.top + (1 - (Math.max(yMin, Math.min(yMax, v)) - yMin) / (yMax - yMin)) * innerH;

const xTicks = [2, 3, 4, 5].filter((t) => t >= xMin && t <= xMax);
const xTickLabel: Record<number, string> = { 2: '100', 3: '1k', 4: '10k', 5: '100k' };
const yTicks = [-50, 0, 50, 100];
const zeroY = yScale(0);

function markerR(studyCount: number): number {
  return 5 + Math.min(7, studyCount);
}
function truncate(s: string, n = 18): string {
  return s.length > n ? s.slice(0, n - 1).trimEnd() + '…' : s;
}

// Build label placements with side-aware, greedy vertical anti-collision.
type Node = {
  t: ComputedTopic; cx: number; cy: number; r: number; yTrue: number; rr: number;
  offLow: boolean; offHigh: boolean; side: 'left' | 'right'; labelY: number; name: string;
};
const nodes: Node[] = pts.map((d) => {
  const cx = xScale(d.x);
  const cy = yScale(d.yTrue);
  const r = markerR(d.t.studyCount);
  return {
    t: d.t, cx, cy, r, yTrue: d.yTrue, rr: d.rr,
    offLow: d.yTrue < yMin, offHigh: d.yTrue > yMax,
    // Labels for dots on the right third flip to the left so they don't overflow.
    side: cx > M.left + innerW * 0.6 ? 'left' : 'right',
    labelY: cy, name: truncate(d.t.raw.name),
  };
});

const LINE_H = 13;
for (const side of ['left', 'right'] as const) {
  const group = nodes.filter((n) => n.side === side).sort((a, b) => a.cy - b.cy);
  let prev = -Infinity;
  for (const n of group) {
    n.labelY = Math.max(n.cy, prev + LINE_H);
    prev = n.labelY;
  }
  // If the greedy pass pushed labels past the bottom, relax upward from the end.
  const overflow = (group.at(-1)?.labelY ?? 0) - (H - M.bottom - 2);
  if (overflow > 0) for (const n of group) n.labelY -= overflow;
}
---
{pts.length > 0 && (
  <div class="table-scroll">
  <svg class="scatter" viewBox={`0 0 ${W} ${H}`} width={W} height={H} role="img"
       aria-label="Benefit on the primary outcome vs. evidence volume across topics">
    <!-- gridlines -->
    {yTicks.map((t) => (
      <g>
        <line class={t === 0 ? 'axis' : 'grid'} x1={M.left} y1={yScale(t)} x2={W - M.right} y2={yScale(t)} />
        <text class="axislabel" x={M.left - 8} y={yScale(t) + 3} text-anchor="end">{t > 0 ? `+${t}` : t}%</text>
      </g>
    ))}

    {xTicks.map((t) => (
      <g>
        <line class="grid vgrid" x1={xScale(t)} y1={M.top} x2={xScale(t)} y2={H - M.bottom} />
        <text class="axislabel" x={xScale(t)} y={H - M.bottom + 16} text-anchor="middle">{xTickLabel[t]}</text>
      </g>
    ))}
    <text class="axistitle" x={M.left + innerW / 2} y={H - 6} text-anchor="middle">Patients analyzed (log scale)</text>
    <text class="axistitle" transform={`translate(15 ${M.top + innerH / 2}) rotate(-90)`} text-anchor="middle">Benefit on primary outcome</text>
    <text class="axishint" x={M.left - 8} y={M.top + 4} text-anchor="end">better ▲</text>

    {nodes.map((n) => {
      const cyC = n.offLow ? yScale(yMin) : n.offHigh ? yScale(yMax) : n.cy;
      const anchor = n.side === 'right' ? 'start' : 'end';
      const lx = n.side === 'right' ? n.cx + n.r + 4 : n.cx - n.r - 4;
      const moved = Math.abs(n.labelY - cyC) > 4;
      const pct = `${n.yTrue >= 0 ? '+' : ''}${n.yTrue.toFixed(0)}%`;
      const off = n.offLow ? ' (off-scale)' : n.offHigh ? ' (off-scale)' : '';
      return (
        <a href={`${base}/topics/${n.t.raw.slug}`}>
          <title>{`${n.t.raw.name} — ${pct}${off} benefit · RR ${n.rr.toFixed(2)} · ${n.t.totalPatients.toLocaleString()} patients · ${n.t.status}`}</title>
          {moved && <line class="leader" x1={n.cx + (n.side === 'right' ? n.r : -n.r)} y1={cyC} x2={lx} y2={n.labelY - 3} />}
          <circle class={`dot ${n.t.status}`} cx={n.cx} cy={cyC} r={n.r} opacity="0.8" />
          {(n.offLow || n.offHigh) && (
            <text class="caret" x={n.cx} y={cyC + (n.offLow ? n.r + 9 : -n.r - 4)} text-anchor="middle">{n.offLow ? '▼' : '▲'}</text>
          )}
          <text class="lbl" x={lx} y={n.labelY} text-anchor={anchor}>{n.name}</text>
        </a>
      );
    })}
  </svg>
  </div>
)}
<p class="small">Each point is a topic, positioned by directional benefit on its primary outcome (y) and total patients analyzed (x, log scale). Positive y favors the intervention; marker size grows with the number of studies; color reflects evidence status. Points beyond ±100% are drawn at the edge with a ▲/▼ caret. Hover for the exact figures; click to open the topic.</p>
