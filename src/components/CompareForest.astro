---
import type { Comparison } from '../lib/compare';
import { fmtRR, fmtCI } from '../lib/format';

interface Props {
  comparison: Comparison;
}
const { comparison } = Astro.props;
const dir = comparison.outcome.direction;
const rows = comparison.rows;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const LABEL_W = 220;
const PLOT_W = 300;
const STAT_W = 130;
const ROW_H = 26;
const PAD_TOP = 24;
const AXIS_H = 46;
const W = LABEL_W + PLOT_W + STAT_W;
const H = PAD_TOP + rows.length * ROW_H + AXIS_H;

const DOMAIN_LO = 0.05;
const DOMAIN_HI = 4;
const ticks = [0.1, 0.25, 0.5, 1, 2, 4];
const logLo = Math.log(DOMAIN_LO);
const logHi = Math.log(DOMAIN_HI);
const plotX0 = LABEL_W;
const plotX1 = LABEL_W + PLOT_W;

function x(rr: number): number {
  const clamped = Math.min(Math.max(rr, DOMAIN_LO), DOMAIN_HI);
  return plotX0 + ((Math.log(clamped) - logLo) / (logHi - logLo)) * PLOT_W;
}
function favorClass(low: number, high: number): 'favor' | 'against' | 'neutral' {
  const benefit = high < 1;
  const harm = low > 1;
  if (dir === 'lowerIsBetter') {
    if (benefit) return 'favor';
    if (harm) return 'against';
  } else {
    if (harm) return 'favor';
    if (benefit) return 'against';
  }
  return 'neutral';
}
const refX = x(1);
---
<div class="table-scroll">
<svg class="forest" viewBox={`0 0 ${W} ${H}`} width={W} height={H} role="img"
     aria-label={`Comparison of interventions for ${comparison.outcome.label}`}>
  <line class="refline" x1={refX} y1={PAD_TOP - 6} x2={refX} y2={PAD_TOP + rows.length * ROW_H + 4} />

  {rows.map((r, i) => {
    const cy = PAD_TOP + i * ROW_H + ROW_H / 2;
    const cls = favorClass(r.pooled.ciLow, r.pooled.ciHigh);
    const cx = x(r.pooled.rr);
    const x0 = x(r.pooled.ciLow);
    const x1 = x(r.pooled.ciHigh);
    const sz = 9;
    return (
      <g>
        <a href={`${base}/topics/${r.topicSlug}`}>
          <text class="study-label" x={6} y={cy + 3}>{r.topicName}</text>
        </a>
        <line class="whisker" x1={x0} y1={cy} x2={x1} y2={cy} />
        <rect class={`study-marker ${cls}`} x={cx - sz / 2} y={cy - sz / 2} width={sz} height={sz} />
        <text class="study-stat" x={plotX1 + 8} y={cy + 3}>
          {`${fmtRR(r.pooled.rr)} [${fmtCI(r.pooled.ciLow, r.pooled.ciHigh)}]`}
        </text>
      </g>
    );
  })}

  {(() => {
    const ay = PAD_TOP + rows.length * ROW_H + 8;
    return (
      <g>
        <line class="axis" x1={plotX0} y1={ay} x2={plotX1} y2={ay} />
        {ticks.map((t) => (
          <g>
            <line class="tick" x1={x(t)} y1={ay} x2={x(t)} y2={ay + 4} />
            <text class="ticklabel" x={x(t)} y={ay + 15} text-anchor="middle">{t}</text>
          </g>
        ))}
        <text class="endlabel" x={plotX0} y={ay + 28} text-anchor="start">← favors intervention</text>
        <text class="endlabel" x={plotX1} y={ay + 28} text-anchor="end">favors control →</text>
      </g>
    );
  })()}
</svg>
</div>
<p class="small">Each row is a different intervention's pooled effect on the same outcome. Interventions are <strong>not</strong> pooled together — this is a comparison, not a meta-analysis.</p>
