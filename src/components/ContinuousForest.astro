---
import type { ComputedOutcome } from '../lib/derive';
import { fmtNum } from '../lib/format';

interface Props {
  outcome: ComputedOutcome;
  favorLabel?: string;
  againstLabel?: string;
}
const { outcome, favorLabel = 'favors treatment', againstLabel = 'favors control' } = Astro.props;
const dir = outcome.outcome.direction;
const rows = outcome.studies;
const p = outcome.contPooled;

const LABEL_W = 170;
const PLOT_W = 320;
const STAT_W = 170;
const ROW_H = 22;
const PAD_TOP = 28;
const AXIS_H = 46;
const W = LABEL_W + PLOT_W + STAT_W;
const plotted = rows.length + (p ? 1 : 0);
const H = PAD_TOP + plotted * ROW_H + AXIS_H;

// Linear axis symmetric around 0 (no effect). Scale to the pooled studies so a
// single excluded outlier (e.g. artifactual SDs) doesn't squash the axis;
// out-of-range markers are clamped to the edge.
const scaleRows = rows.filter((r) => !r.excludeFromPooled && r.cont);
const vals = (scaleRows.length ? scaleRows : rows)
  .flatMap((r) => (r.cont ? [r.cont.ciLow, r.cont.ciHigh] : []))
  .concat(p ? [p.ciLow, p.ciHigh] : []);
const dom = Math.max(0.5, ...vals.map((v) => Math.abs(v))) * 1.15;
const plotX0 = LABEL_W;
const plotX1 = LABEL_W + PLOT_W;
function x(v: number): number {
  const c = Math.min(Math.max(v, -dom), dom);
  return plotX0 + ((c + dom) / (2 * dom)) * PLOT_W;
}
function favorClass(lo: number, hi: number): 'favor' | 'against' | 'neutral' {
  const reduces = hi < 0;
  const increases = lo > 0;
  if (dir === 'lowerIsBetter') {
    if (reduces) return 'favor';
    if (increases) return 'against';
  } else {
    if (increases) return 'favor';
    if (reduces) return 'against';
  }
  return 'neutral';
}
function markerSize(weightPct: number): number {
  return 4 + Math.sqrt(Math.max(0, weightPct)) * 8;
}
const refX = x(0);
const step = dom > 4 ? 2 : dom > 2 ? 1 : dom > 1 ? 0.5 : 0.25;
const ticks: number[] = [];
for (let t = Math.ceil(-dom / step) * step; t <= dom + 1e-9; t += step) ticks.push(Number(t.toFixed(2)));
const pooledCls = p ? favorClass(p.ciLow, p.ciHigh) : 'neutral';
---
<div class="table-scroll">
<svg class="forest" viewBox={`0 0 ${W} ${H}`} width={W} height={H} role="img"
     aria-label={`Forest plot for ${outcome.outcome.label}`}>
  <line class="refline" x1={refX} y1={PAD_TOP - 6} x2={refX} y2={PAD_TOP + plotted * ROW_H + 4} />

  {rows.map((s, i) => {
    const cy = PAD_TOP + i * ROW_H + ROW_H / 2;
    if (!s.cont) return null;
    const cls = favorClass(s.cont.ciLow, s.cont.ciHigh);
    const cx = x(s.cont.estimate);
    const sz = markerSize(s.weightPct);
    return (
      <g>
        <text class="study-label" x={6} y={cy + 3}>{`${s.author} ${s.year}`}</text>
        <line class="whisker" x1={x(s.cont.ciLow)} y1={cy} x2={x(s.cont.ciHigh)} y2={cy} />
        <rect class={`study-marker ${cls}`} x={cx - sz / 2} y={cy - sz / 2} width={sz} height={sz} />
        <text class="study-stat" x={plotX1 + 8} y={cy + 3}>
          {`${fmtNum(s.cont.estimate)} [${fmtNum(s.cont.ciLow)}, ${fmtNum(s.cont.ciHigh)}]`}
        </text>
      </g>
    );
  })}

  {p && (() => {
    const cy = PAD_TOP + rows.length * ROW_H + ROW_H / 2;
    const hh = 6;
    return (
      <g>
        <text class="study-label" x={6} y={cy + 3} style="font-weight:700">Pooled (RE)</text>
        <polygon class={`diamond ${pooledCls}`}
          points={`${x(p.ciLow)},${cy} ${x(p.estimate)},${cy - hh} ${x(p.ciHigh)},${cy} ${x(p.estimate)},${cy + hh}`} />
        <text class="study-stat" x={plotX1 + 8} y={cy + 3} style="font-weight:700">
          {`${fmtNum(p.estimate)} [${fmtNum(p.ciLow)}, ${fmtNum(p.ciHigh)}]`}
        </text>
      </g>
    );
  })()}

  {(() => {
    const ay = PAD_TOP + plotted * ROW_H + 8;
    return (
      <g>
        <line class="axis" x1={plotX0} y1={ay} x2={plotX1} y2={ay} />
        {ticks.map((t) => (
          <g>
            <line class="tick" x1={x(t)} y1={ay} x2={x(t)} y2={ay + 4} />
            <text class="ticklabel" x={x(t)} y={ay + 15} text-anchor="middle">{t}</text>
          </g>
        ))}
        <text class="endlabel" x={plotX0} y={ay + 28} text-anchor="start">← {favorLabel}</text>
        <text class="endlabel" x={plotX1} y={ay + 28} text-anchor="end">{againstLabel} →</text>
      </g>
    );
  })()}
</svg>
</div>
<p class="small">Effect is a {outcome.measure === 'SMD' ? 'standardized ' : ''}mean difference; the no-effect line is at 0. The diamond is the pooled random-effects estimate.</p>
