---
import type { RawStudy } from '../lib/derive';

interface Props {
  studies: RawStudy[];
}
const { studies } = Astro.props;
---
<ul class="recent">
  {studies.map((s) => (
    <li>
      <strong>{s.year}</strong> · <span class="tag">{s.design}</span>{' '}
      {s.url || s.doi ? (
        <a href={s.url ?? `https://doi.org/${s.doi}`} target="_blank" rel="noopener">{s.citation}</a>
      ) : (
        <span>{s.citation}</span>
      )}
    </li>
  ))}
</ul>
<style>
  .recent { list-style: none; padding: 0; margin: .5rem 0; }
  .recent li { padding: .45rem 0; border-bottom: 1px solid var(--line); font-size: .88rem; }
</style>
