---
import { getCollection } from 'astro:content';
import TopicLayout from '../../layouts/TopicLayout.astro';
import { deriveTopic, type RawTopic } from '../../lib/derive';

export async function getStaticPaths() {
  const entries = await getCollection('topics');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { topic: deriveTopic(entry.data as RawTopic) },
  }));
}

const { topic } = Astro.props;
---
<TopicLayout topic={topic} />
