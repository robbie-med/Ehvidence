---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { deriveTopic, type RawTopic } from '../../lib/derive';
import { buildComparisons } from '../../lib/compare';
import { PROBLEMS } from '../../lib/standardOutcomes';
import { fmtPct } from '../../lib/format';

const entries = await getCollection('topics');
const topics = entries.map((e) => deriveTopic(e.data as RawTopic));
const comparisons = buildComparisons(topics, 2);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const byProblem = PROBLEMS.map((p) => ({
  problem: p,
  items: comparisons.filter((c) => c.outcome.problemId === p.id),
})).filter((g) => g.items.length > 0);
---
<BaseLayout title="Compare interventions—Ehvidence" description="Compare different interventions for the same precisely-defined outcome.">
  <h1>Compare interventions</h1>
  <p class="tagline muted">
    Each comparison fixes one precisely-defined outcome and lines up every intervention measured
    against it—varied treatments for the same problem, on one axis. Interventions are not pooled
    together; populations differ, so relative effects are comparable but absolute benefit is not.
  </p>

  {byProblem.map((g) => (
    <section>
      <h2>{g.problem.label}</h2>
      {g.problem.description && <p class="small muted">{g.problem.description}</p>}
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>Outcome (the question)</th>
              <th class="num">Interventions</th>
              <th>Best result</th>
            </tr>
          </thead>
          <tbody>
            {g.items.map((c) => {
              const best = c.rows[0];
              return (
                <tr>
                  <td><a href={`${base}/compare/${c.outcome.id}`}>{c.outcome.label}</a>{c.outcome.caveat && <span class="tag" title={c.outcome.caveat}> definitions vary</span>}</td>
                  <td class="num">{c.rows.length}</td>
                  <td>{best.topicName} ({fmtPct(best.pooled.improvementPct)} lower)</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>
  ))}
</BaseLayout>
