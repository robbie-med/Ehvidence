---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TopicCards from '../components/TopicCards.astro';
import SearchBox from '../islands/SearchBox.tsx';
import { deriveTopic, type RawTopic } from '../lib/derive';
import { fmtInt } from '../lib/format';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const entries = await getCollection('topics');
const topics = entries.map((e) => deriveTopic(e.data as RawTopic));

const topicCount = topics.length;
const studyCount = topics.reduce((s, t) => s + t.studyCount, 0);
const patientCount = topics.reduce((s, t) => s + t.totalPatients, 0);
---
<BaseLayout
  title="Ehvidence—real-time analysis of medical evidence"
  description="Number needed to treat, number needed to harm, and pooled effects across clinical topics."
>
  <section class="hero">
    <h1>Real-time analysis of medical evidence</h1>
    <p class="tagline">
      Pooled effects, number needed to treat, and number needed to harm across clinical topics —
      every metric recomputed from the underlying study data.
    </p>
    <SearchBox
      client:load
      base={base}
      variant="hero"
      placeholder="Search topics, conditions, interventions…"
    />
    <div class="stat-strip">
      <div class="s"><div class="n">{fmtInt(topicCount)}</div><div class="l">Topics</div></div>
      <div class="s"><div class="n">{fmtInt(studyCount)}</div><div class="l">Studies</div></div>
      <div class="s"><div class="n">{fmtInt(patientCount)}</div><div class="l">Patients</div></div>
    </div>
  </section>

  <div class="browse-hint small">
    Browse every topic as a <a href={`${base}/browse`}>ranked table and efficacy scatter</a>, or
    jump straight in below.
  </div>

  <TopicCards topics={topics} />
</BaseLayout>
